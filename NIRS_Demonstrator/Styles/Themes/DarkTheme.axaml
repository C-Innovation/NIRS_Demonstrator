<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Color x:Key="Theme_BackgroundMain">#686868</Color>
	<SolidColorBrush x:Key="Theme_BackgroundMainBrush" Color="{StaticResource Theme_BackgroundMain}"/>

	<Color x:Key="Theme_ForegroundMain">#efefef</Color>
	<SolidColorBrush x:Key="Theme_ForegroudMainBrush" Color="{StaticResource Theme_ForegroundMain}"/>

	<Color x:Key="Theme_TitleBackground">#484848</Color>
	<SolidColorBrush x:Key="Theme_TitleBackgroundBrush" Color="{StaticResource Theme_TitleBackground}"/>

	<Color x:Key="GreekBlue">#45b6e5</Color>
	<SolidColorBrush x:Key="Theme_GreekBlueBrush" Color="{StaticResource GreekBlue}" />
</ResourceDictionary>
