<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
			 xmlns:local="clr-namespace:NIRS_Demonstrator"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="NIRS_Demonstrator.MainMenuItemControl"
			 Background="Transparent"
			 Margin="5">

	<UserControl.Styles>
		<!--<Style Selector="Border.Anim">
			<Setter Property="BorderBrush" Value="{DynamicResource Theme_ForegroudMainBrush}" />
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
				</Transitions>
				
			</Setter>

			
			
		</Style>
		
		<Style Selector="Border.Anim:pointerover">
			<Setter Property="BorderBrush" Value="Red"/>
			
		</Style>-->


		
	</UserControl.Styles>
	<Border x:Name="MainBorder"
			Background="Transparent"
			BorderThickness="5"
			CornerRadius="10" 
			Classes="Anim"
			
			BorderBrush="{DynamicResource Theme_ForegroudMainBrush}">
		<!-- Classes.triggered="{Binding PointerEntered}" -->
		<!--<Border.Styles>
			<Style Selector="Border.triggered">
				<Style.Animations>
					<Animation Duration="0:0:0.3">
						<KeyFrame Cue="0%">
							<Setter Property="BorderBrush" Value="{DynamicResource Theme_ForegroudMainBrush}"/>
						</KeyFrame>
						<KeyFrame Cue="100%">
							<Setter Property="BorderBrush" Value="Red"/>
						</KeyFrame>
					</Animation>
				</Style.Animations>
			</Style>
		</Border.Styles>-->

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<i:Icon x:Name="ButtonIcon"
					Classes="Anim"
					Grid.Row="0"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Value="fa-solid fa-palette"
					FontSize="{StaticResource FontSizeXXXXXLarge}"
					Margin="5" 
					Foreground="{DynamicResource Theme_ForegroudMainBrush}"
					>
				
				
				<!--<i:Icon.Styles>
					<Style Selector=":is(i|Icon).Anim">
						
							<Setter Property="Foreground" Value="{DynamicResource Theme_ForegroudMainBrush}" />
							<Setter Property="Transitions">
								<Transitions>
									<BrushTransition Property="Foreground" Duration="0:0:0.2"/>
								</Transitions>

							</Setter>



						</Style>

						<Style Selector=":is(i|Icon).Anim:pointerover">
							<Setter Property="Foreground" Value="Red"/>

						</Style>
					
					
				</i:Icon.Styles>-->
			</i:Icon>

			<TextBlock x:Name="HeaderTextBlock"
                       Grid.Row="1"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="{StaticResource FontSizeXLarge}"
                       FontStyle="Italic"
					   Foreground="{DynamicResource Theme_ForegroudMainBrush}">
				
			</TextBlock>
			<!--<TextBlock x:Name="HeaderTextBlock"
					   Grid.Row="1"
					   FontFamily="{StaticResource LatoBold}"
					   HorizontalAlignment="Center"
					   VerticalAlignment="Center"
					   FontSize="{StaticResource FontSizeXLarge}"
					   FontWeight="Bold"
					   FontStyle="Italic">
				<TextBlock.Style>
					<Style TargetType="TextBlock">
						<Setter Property="Foreground" Value="{DynamicResource Theme_ForegroudMainBrush}" />

					</Style>
				</TextBlock.Style>
			</TextBlock>-->
		</Grid>



	</Border>
</UserControl>
