<local:BasePage x:TypeArguments="vm:MainPageViewModel" xmlns="https://github.com/avaloniaui"
				xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
				xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
				xmlns:local="clr-namespace:NIRS_Demonstrator"
				xmlns:vm="clr-namespace:NIRS_Demonstrator.ViewModels"
				mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
				x:Class="NIRS_Demonstrator.MainPage"
				x:CompileBindings="False"
				>

	<Grid x:Name="MainGrid" RowDefinitions="Auto,*, Auto" 
		  
		  >

		
		
		<Grid x:Name="MenuGrid" Grid.Row="1"
			  HorizontalAlignment="Center"
			  VerticalAlignment="Center">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<local:MainMenuItemControl Grid.Column="0"
                                       Grid.Row="0"
                                       Height="200"
                                       Width="170"
                                       
                                       Icon="fa-solid fa-terminal"
                                       Header="{DynamicResource TerminalText}"
                                       Command="{Binding RunTerminalCommand}"
									   CommandParameter="2"/>
			<local:MainMenuItemControl Grid.Column="1"
                                       Grid.Row="0"
                                       Height="200"
                                       Width="170"
                                       Icon="fa-solid fa-chart-line"
                                       Header="{DynamicResource ChartsText}"
                                       Command="{Binding RunChartsCommand}"
									   CommandParameter="2"/>

			
		</Grid>

		<Grid x:Name="TopButtonsGrid"
			  Grid.Row="0"
			  ColumnDefinitions="Auto, *, Auto">
			
				<!--ToolTip.Tip="{DynamicResource SettingsText}"-->

			<Button x:Name="SettingsButton"
					Grid.Column="2"
					Grid.RowSpan="3"
					Classes="IconGrowButton"
					Width="50"
					Height="50"
					Margin="0 10 10 0"
					Content="{StaticResource FA_GearIcon}"
					FontSize="{StaticResource FontSizeXXLarge}"
					Foreground="{DynamicResource Theme_ForegroudMainBrush}"
					ToolTip.Tip="{DynamicResource SettingsText}"
					FontWeight="Bold"
					HorizontalAlignment="Right"
					VerticalAlignment="Top"
					Command="{Binding RunSettingsCommand}"/>
		</Grid>
		
	</Grid>




</local:BasePage>
