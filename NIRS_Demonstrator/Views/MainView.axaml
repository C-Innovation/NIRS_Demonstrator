<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogHost="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             xmlns:vm="using:NIRS_Demonstrator.ViewModels"
             xmlns:local="clr-namespace:NIRS_Demonstrator"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="NIRS_Demonstrator.Views.MainView"
             x:DataType="vm:MainViewModel">
    <Grid Background="{DynamicResource Theme_BackgroundMainBrush}">

        <local:PageHost CurrentPage="{Binding ApplicationViewModel.CurrentPage, Source={x:Static local:ViewModelLocator.Instance}}"
                        CurrentPageViewModel="{Binding ApplicationViewModel.CurrentPageViewModel, Source={x:Static local:ViewModelLocator.Instance}}"
                        />
        <dialogHost:DialogHost
        CloseOnClickAway="False"
        BorderBrush="{DynamicResource Theme_ForegroudMainBrush}"
        BorderThickness="3"
        CornerRadius="10"
        Background="{DynamicResource Theme_BackgroundMainBrush}">
            <dialogHost:DialogHost.DialogContent >

            </dialogHost:DialogHost.DialogContent>

        </dialogHost:DialogHost>
    </Grid>
</UserControl>
